{
    "version": 6,
    "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },

    "configurePresets": [
        {
            "name": "base-gcc-rl78l13",
            "hidden": true,
            "generator": "Ninja",
            "toolchainFile": "${sourceDir}/Code/HAL/RL78_L13/toolchain_gcc.cmake",
            "warnings": { "dev": false }
        },
        {
            "name": "debug",
            "displayName": "Debug - GCC / RL78-L13",
            "description": "Minimal optimisation (-Og), full DWARF debug info",
            "inherits": "base-gcc-rl78l13",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "displayName": "Release - GCC / RL78-L13",
            "description": "Size-optimised (-Os), no debug info",
            "inherits": "base-gcc-rl78l13",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "test",
            "displayName": "ModuleTest - GCC / Host",
            "description": "Host GCC build of all module tests, run via CTest",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/test",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "BUILD_TESTS": "ON",
                "CMAKE_C_COMPILER": "C:/FW_Build_Tools/Mingw32/bin/gcc.exe"
            },
            "warnings": { "dev": false }
        }
    ],

    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build Debug",
            "configurePreset": "debug"
        },
        {
            "name": "release",
            "displayName": "Build Release",
            "configurePreset": "release"
        },
        {
            "name": "test",
            "displayName": "Build Module Tests",
            "configurePreset": "test"
        }
    ],

    "testPresets": [
        {
            "name": "test",
            "displayName": "Run Module Tests",
            "configurePreset": "test",
            "output": { "outputOnFailure": true },
            "execution": { "stopOnFailure": true }
        }
    ]
}
